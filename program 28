a = int(input("Enter first number: "))
b = int(input("Enter second number: "))

sum1 = 0
for i in range(1, a):
    if a % i == 0:
        sum1 += i

sum2 = 0
for i in range(1, b):
    if b % i == 0:
        sum2 += i

if sum1 == b and sum2 == a:
    print("Friendly Pair")
else:
    print("Not a Friendly Pair")
//friendly pair